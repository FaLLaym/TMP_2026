@startuml
left to right direction
actor Кассир
actor Покупатель
actor Администратор

rectangle "Система продажи билетов" {
  usecase "Купить билет" as UC1
  usecase "Сдать билет" as UC2
  usecase "Купить абонемент" as UC3
  usecase "Сдать абонемент" as UC4
  usecase "Посмотреть схему стадиона" as UC5
  usecase "Выбрать место" as UC6
  usecase "Оплатить" as UC7
  usecase "Отменить продажу" as UC8
  usecase "Настроить матчи и цены" as UC9
  usecase "Проверить возможность возврата" as UC10
}

Кассир --> UC1
Кассир --> UC2
Кассир --> UC3
Кассир --> UC4
Покупатель --> UC5
Администратор --> UC8
Администратор --> UC9

UC1 .> UC6 : <<include>>
UC1 .> UC7 : <<include>>
UC2 .> UC10 : <<extend>>
UC3 .> UC7 : <<include>>
UC4 .> UC10 : <<extend>>
@enduml